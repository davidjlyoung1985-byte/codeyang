# CodeYang Configuration
# Copy this file to .env or .env.local and fill in your settings.
# .env is loaded at startup (existing env vars are NOT overridden).

# === API Key (pick one) ===
# DEEPSEEK_API_KEY=sk-...
# CODEYANG_API_KEY=sk-...

# === Provider ===
# API base URL (default: https://api.deepseek.com/v1)
# For OpenAI-compatible: set your custom endpoint
# CODEYANG_BASE_URL=https://api.deepseek.com/v1

# Model name (default: deepseek-chat)
# CODEYANG_MODEL=deepseek-chat

# === Agent Settings ===
# Max tokens per API call (default: 8192)
# CODEYANG_MAX_TOKENS=32000

# Max conversation turns per prompt (default: 40)
# CODEYANG_MAX_TURNS=40

# LLM temperature 0.0-1.0 (default: 0.5)
# CODEYANG_TEMPERATURE=0.5

# Single tool execution timeout in ms (default: 30000)
# CODEYANG_TOOL_TIMEOUT=30000

# === Closed-Loop System ===
# Auto-verify after Write/Edit (default: true)
# CODEYANG_AUTO_VERIFY=true

# Auto-fix lint errors (default: true)
# CODEYANG_AUTO_FIX=true

# File watch mode (default: true)
# CODEYANG_WATCH=true

# === Reflexion (Self-Improvement) ===
# Enable self-reflection on failures (default: true)
# CODEYANG_REFLEXION=true

# Consecutive failures before reflection (default: 2)
# CODEYANG_REFLEXION_THRESHOLD=2

# Max stored reflections (default: 50)
# CODEYANG_REFLEXION_MAX=50

# Auto-inject learned patterns (default: true)
# CODEYANG_REFLEXION_AUTO_INJECT=true

# === Planner (Plan-and-Solve) ===
# Enable planner for complex tasks (default: true)
# CODEYANG_PLANNER=true

# Auto-detect complex tasks (default: true)
# CODEYANG_PLANNER_AUTO=true

# Complexity threshold (sentences, default: 3)
# CODEYANG_PLANNER_THRESHOLD=3

# Require user approval before execution (default: true)
# CODEYANG_PLANNER_APPROVAL=true

# === Memory ===
# Memory cache TTL in ms (default: 30000)
# CODEYANG_MEMORY_CACHE_TTL=30000

# Max cached memory entries (default: 500)
# CODEYANG_MEMORY_MAX_ENTRIES=500

# === Security ===
# Sandbox directory — restricts file access (default: disabled)
# CODEX_SANDBOX=/path/to/allowed/dir

# Whitelist specific Windows drives (comma-separated, e.g. E,F)
# CODEYANG_ALLOW_DRIVES=E,F

# Deny list for Bash commands (comma-separated)
# CODEYANG_DENY_COMMANDS=rm,chmod,dd

# Trusted Git hosts (comma-separated, for git clone)
# CODEYANG_TRUSTED_GIT_HOSTS=github.com,gitlab.com

# Allow unsafe MCP commands (npx, python, docker) — NOT RECOMMENDED
# CODEYANG_MCP_ALLOW_UNSAFE=false

# === MCP Servers ===
# Configure in ~/.codeyang/config.json (not .env)
# See README.md for examples

# === Debug ===
# Enable debug mode (set to true)
# CODEYANG_DEBUG=false

# Debug filter (categories: tool,agent,perf,trace,inspect)
# CODEYANG_DEBUG_FILTER=tool,perf

# Trace distributed operations (default: false)
# CODEYANG_TRACE_ENABLED=false

# Log level: debug|info|warn|error (default: info)
# CODEYANG_LOG_LEVEL=info

# === Performance ===
# Enable LRU cache for tool results (default: true)
# CODEYANG_CACHE_ENABLED=true

# Cache size (max entries, default: 100)
# CODEYANG_CACHE_SIZE=100

# Cache TTL in milliseconds (default: 10000)
# CODEYANG_CACHE_TTL_MS=10000

# === Anthropic API (if using Claude) ===
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CODEYANG_MODEL=claude-opus-4
