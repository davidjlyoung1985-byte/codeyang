{
  "name": "codeyang",
  "version": "0.4.0",
  "description": "Terminal-based AI coding agent powered by Claude",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codeyang": "./dist/index.js",
    "codeyangx": "./dist/codeyangx.js"
  },
  "files": [
    "dist",
    "codeyangx"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup src/index.ts --format esm --clean --sourcemap --watch --outDir dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "execa": "^9.3.0",
    "fast-xml-parser": "^5.8.0",
    "jiti": "^2.7.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.1",
    "electron": "^42.3.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
