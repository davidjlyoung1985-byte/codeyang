{
  "name": "codeyang",
  "version": "0.2.0",
  "description": "Terminal-based AI coding agent powered by Claude",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "codeyang": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
