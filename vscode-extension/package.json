{
  "name": "codeyang-vscode",
  "displayName": "CodeYang AI Agent",
  "version": "0.2.0",
  "description": "AI coding agent powered by Claude — chat with tool-using CodeYang inside VS Code",
  "publisher": "codeyang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeyang.startChat"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeyang.startChat",
        "title": "CodeYang: Start Chat"
      }
    ],
    "configuration": {
      "title": "CodeYang",
      "properties": {
        "codeyang.apiKey": {
          "type": "string",
          "description": "Anthropic API Key for CodeYang AI agent",
          "default": ""
        },
        "codeyang.apiBaseUrl": {
          "type": "string",
          "description": "API Base URL (default: https://api.anthropic.com)",
          "default": "https://api.anthropic.com"
        },
        "codeyang.model": {
          "type": "string",
          "description": "Claude model to use (e.g. claude-sonnet-4-20250514)",
          "default": "claude-sonnet-4-20250514"
        }
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0"
  }
}
