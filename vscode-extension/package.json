{
  "name": "codeyang-vscode",
  "displayName": "CodeYang AI Agent",
  "version": "0.2.0",
  "description": "AI coding agent — chat with tool-using CodeYang inside VS Code",
  "publisher": "codeyang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeyang.startChat"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeyang.startChat",
        "title": "CodeYang: Start Chat"
      }
    ],
    "configuration": {
      "title": "CodeYang",
      "properties": {
        "codeyang.apiKey": {
          "type": "string",
          "description": "API Key for CodeYang AI agent (supports DeepSeek, Anthropic)",
          "default": ""
        },
        "codeyang.apiBaseUrl": {
          "type": "string",
          "description": "API Base URL (default: https://api.deepseek.com/v1)",
          "default": "https://api.deepseek.com/v1"
        },
        "codeyang.model": {
          "type": "string",
          "description": "Model to use (e.g. deepseek-chat, claude-sonnet-4-20250514)",
          "default": "deepseek-chat"
        }
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0"
  }
}
