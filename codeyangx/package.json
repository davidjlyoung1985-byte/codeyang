{
  "name": "codeyangx",
  "version": "0.3.0",
  "description": "CodeYangX - AI Coding Agent Desktop App",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.codeyangx.app",
    "productName": "CodeYangX",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "tools.cjs",
      "mcp.cjs",
      "security.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": ["portable"],
      "artifactName": "CodeYangX-Portable-${version}.exe",
      "sign": false
    },
    "portable": {
      "requestExecutionLevel": "user"
    },
    "electronDist": "node_modules/electron/dist"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  }
}
